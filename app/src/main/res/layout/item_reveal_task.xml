<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_task_card"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_task_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Task Title Placeholder"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000" />

        <TextView
            android:id="@+id/tv_task_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target: 2000 steps"
            android:textSize="14sp"
            android:textColor="#4B5563"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/btn_shuffle_item"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:button="@null"
        android:background="@android:drawable/checkbox_on_background"
        android:contentDescription="Complete Task Checkbox"
        android:focusable="false"
        android:clickable="false" />

    <ImageView
        android:id="@+id/iv_auto_tracked_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@android:drawable/ic_menu_compass"
        android:contentDescription="Auto-tracked quest"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false"
        android:alpha="0.7" />

    <Button
        android:id="@+id/btn_start_avoidance"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Start"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:backgroundTint="#778A66"
        android:visibility="gone"
        android:paddingLeft="20dp"
        android:paddingRight="20dp" />

    <Button
        android:id="@+id/btn_increment_progress"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#778A66"
        android:visibility="gone"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp" />

</LinearLayout>