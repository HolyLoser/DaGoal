<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <View
        android:id="@+id/view_achievement_badge_bg"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_achievement_badge" />

    <ImageView
        android:id="@+id/iv_achievement_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_menu_myplaces"
        android:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tv_achievement_rank_badge"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:background="@drawable/bg_achievement_rank_badge"
        android:gravity="center"
        android:text="1"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

</FrameLayout>