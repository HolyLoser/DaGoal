<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_panel_rounded"
    android:padding="20dp">

    <TextView
        android:id="@+id/tv_wardrobe_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Outfits Bag"
        android:textColor="#2D3748"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:id="@+id/iv_avatar_preview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <GridView
            android:id="@+id/grid_wardrobe_items"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:numColumns="3"
            android:horizontalSpacing="16dp"
            android:verticalSpacing="16dp"
            android:stretchMode="columnWidth" />
    </FrameLayout>

    <Button
        android:id="@+id/btn_wardrobe_action"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:backgroundTint="#778A66"
        android:text="Equip Item"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textAllCaps="false" />
</LinearLayout>